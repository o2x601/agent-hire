############################################################
# Supabase Self-hosted — docker-compose 用環境変数
# cp .env.docker.example .env.docker
# docker compose --env-file .env.docker up -d
############################################################

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_PASSWORD=your-super-secret-postgres-password
POSTGRES_DB=postgres

# ── JWT ─────────────────────────────────────────────────────
# 本番では必ず強力なランダム文字列に変更すること (32文字以上)
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# 以下は JWT_SECRET で署名した JWTトークン
# 開発用サンプルキー (JWT_SECRET が上記のデフォルト値の場合のみ有効)
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.dc_X5iR_VP_qroESPFJ1a-11qw5uHoZ38_SKsFrFPPs
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTY0MTc2OTIwMCwiZXhwIjoxNzk5NTM1NjAwfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

# ── サイト設定 ───────────────────────────────────────────────
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:54321

# ── Studio ──────────────────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-in-production

# ── Supabase Storage ────────────────────────────────────────
STORAGE_BACKEND=file
STORAGE_FILE_SIZE_LIMIT=52428800

# ── SMTP (メール送信) ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_SENDER_NAME=Agent-Hire

# ── FastAPI Backend ──────────────────────────────────────────
FASTAPI_PORT=8000
OLLAMA_BASE_URL=http://host.docker.internal:11434
OPENAI_API_KEY=
ENCRYPTION_KEY=your-fernet-key-here
